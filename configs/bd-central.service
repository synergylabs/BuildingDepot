[Unit]
Description=BuildingDepot Central Service
After=network.target bd-replica.service
Requires=bd-replica.service

[Service]
Type=simple
WorkingDirectory=/srv/BuildingDepot/buildingdepot
ExecStart=/snap/bin/uv run --env-file=../.env gunicorn -w 4 -b 127.0.0.1:8081 CentralService:app
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
