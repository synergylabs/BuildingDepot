[Unit]
Description=BuildingDepot Central Service
After=network.target bd-replica.service
Requires=bd-replica.service

[Service]
Type=simple
WorkingDirectory=/srv/buildingdepot
ExecStart=/srv/buildingdepot/venv/bin/uwsgi /etc/uwsgi/apps-available/cs.ini
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
