[Unit]
Description=BuildingDepot Data Service
After=network.target bd-central.service
Requires=bd-central.service

[Service]
Type=simple
WorkingDirectory=/srv/buildingdepot
ExecStart=/srv/buildingdepot/venv/bin/uwsgi /etc/uwsgi/apps-available/ds.ini
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
